# Copy this file to `.env` and fill in real values.
# Never commit `.env`.

# Required for Tier 1 OpenAI-backed agents.
OPENAI_API_KEY=sk-your-key-here

# Recommended default for the API Counterfactualist pilot.
OPENAI_COUNTERFACTUAL_MODEL=gpt-4.1-mini

# Cheapest smoke-test option. Useful for plumbing, weaker for final perturbation quality.
# OPENAI_COUNTERFACTUAL_MODEL=gpt-4.1-nano

# Keep API usage bounded during pilot runs.
COUNTERFACTUAL_MAX_OUTPUT_TOKENS=4000

# Optional local Proposer via Ollama.
# Install Ollama, then run: ollama pull llama3.1:8b
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_PROPOSER_MODEL=llama3.1:8b
OLLAMA_TIMEOUT_SECONDS=180
PROPOSER_TEMPERATURE=0.2

# Optional hosted Proposers for model-comparison experiments.
OPENAI_PROPOSER_MODEL=gpt-5-mini
ANTHROPIC_API_KEY=sk-ant-your-key-here
ANTHROPIC_PROPOSER_MODEL=claude-haiku-4-5
ANTHROPIC_TIMEOUT_SECONDS=180
PROPOSER_MAX_OUTPUT_TOKENS=512
OPENAI_PROPOSER_REASONING_EFFORT=minimal

# Optional API Maieutic Inquirer.
OPENAI_MAIEUTIC_MODEL=gpt-4.1-mini
MAIEUTIC_MAX_OUTPUT_TOKENS=1200

# Optional API Judge for CSR contradiction classification.
OPENAI_JUDGE_MODEL=gpt-4.1-mini
JUDGE_MAX_OUTPUT_TOKENS=800
